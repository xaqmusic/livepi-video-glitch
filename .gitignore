# Build artifacts
obj/
bin/*
!bin/data/
!bin/data/**
*.o
*.d

# Local machine config / secrets -- copy the checked-in .example versions
.env
bin/data/config/app.local.json

# SSH keys accidentally generated into the repo dir instead of ~/.ssh/
id_rsa*
id_ed25519*
id_ecdsa*
*.pem
*_deploy
*_deploy.pub

# Full-resolution gig footage -- see bin/data/clips/README.md
bin/data/clips/*
!bin/data/clips/.gitkeep
!bin/data/clips/samples/
!bin/data/clips/samples/**
!bin/data/clips/README.md
# The clip-id registry fixture IS tracked (dev seed; the Pi's copy is
# backend-owned and protected from deploys via .rsyncfilter)
!bin/data/clips/library.json

# Backend (Python) and frontend (Node) local state
backend/.venv/
backend/.env
__pycache__/
frontend/node_modules/
frontend/dist/

# OS / editor cruft
.DS_Store
*.swp
.vscode/ipch/
bin/data/shows/*
!bin/data/shows/default.json
!bin/data/shows/active.json
