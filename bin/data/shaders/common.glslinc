// Shared helpers, textually inlined via `#pragma include "common.glslinc"`.
// Keep this file free of #version/precision lines -- ShaderLoader prepends
// those once, to the fully-assembled source, not per include.

float hash(float n) {
    return fract(sin(n) * 43758.5453123);
}

float noise(float x) {
    float i = floor(x);
    float f = fract(x);
    float u = f * f * (3.0 - 2.0 * f);
    return mix(hash(i), hash(i + 1.0), u);
}
