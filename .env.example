# Copy to .env and fill in for your setup. .env is gitignored -- these are
# machine-specific paths/hosts, not secrets, but they still shouldn't be
# committed since the desktop and the Pi will have different values.
# Used by scripts/deploy-to-pi.sh.

PI_HOST=
PI_USER=pi
PI_APP_DIR=/home/pi/livepi-video-glitch
PI_OF_ROOT=/home/pi/openFrameworks
